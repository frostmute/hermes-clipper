{
  "manifest_version": 3,
  "name": "Hermes Clipper",
  "version": "0.1.0",
  "description": "Intelligent web clipping for Obsidian via Hermes Agent.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
